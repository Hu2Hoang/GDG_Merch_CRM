# ── Cloudflare R2 Upload Config ──────────────────────────────────────────────
# Copy file này thành .env rồi điền giá trị thật (không commit .env lên git!)

# Lấy Account ID tại: Cloudflare Dashboard → R2 → Account ID (góc phải)
R2_ACCOUNT_ID=your_account_id_here

# Tạo API Token tại: R2 → Manage R2 API Tokens → Create API Token
# Cấp quyền: Object Read & Write cho bucket cụ thể
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key

# Tên bucket R2 của bạn
R2_BUCKET=gdg-cdn

# Custom domain hoặc r2.dev public URL của bucket
# Nếu dùng custom domain: https://r2.cdn.gdghanoi.com
# Nếu dùng r2.dev:        https://pub-xxxx.r2.dev
R2_PUBLIC_URL=https://r2.cdn.gdghanoi.com
